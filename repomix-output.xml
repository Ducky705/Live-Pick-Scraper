def _call_openrouter(image_path: str, prompt: str, prompt_type: str) -> OCRResult:
    """
    Call OpenRouter with reliable vision models.
    """
    start = time.time()

    try:
        from src.openrouter_client import openrouter_completion

        # Primary: Llama 3.2 90B Vision (if available/free) or Gemma
        # Fallback list handled by client if specific model fails? No, client is simple.
