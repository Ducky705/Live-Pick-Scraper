    old_graded = old_stats.get('Win', 0) + old_stats.get('Loss', 0) + old_stats.get('PUSH', 0)
    new_graded = new_stats.get('WIN', 0) + new_stats.get('LOSS', 0) + new_stats.get('PUSH', 0)
