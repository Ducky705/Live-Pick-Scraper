        log_info(f"Saved to: {output_file}")

    # Also save to file for reference
    output_file = CACHE_DIR / "grading_prompt.md"
    with open(output_file, "w", encoding="utf-8") as f:
        f.write(prompt)
    log_info(f"Also saved to: {output_file}")

    # Print preview
