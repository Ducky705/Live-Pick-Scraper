    print(f"@mention extraction:")
    print(f"  Caption: {caption}")
    print(f"  Extracted cappers: {result.capper_names}")
    print(f"  Mappings: {result.mappings}")
    print(f"  Confidence: {result.confidence:.0%}")
    
