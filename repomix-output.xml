      transition: all 0.2s;
    }

    .btn-remove:hover {
      color: var(--danger);
      background: var(--danger-bg);
    }

    /* New Pick Area */
    .new-pick-area {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 16px;
      position: relative;
    }

    .new-pick-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-main);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .new-pick-title::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .grid-3 {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
    }

    .action-bar {
      border-top: 1px solid var(--border);
      padding: 20px 24px;
      background: rgba(9, 9, 11, 0.95);
      display: flex;
      gap: 12px;
    }

    .link-btn {
      background: none;
      border: none;
      color: var(--primary);
      font-size: 12px;
      font-weight: 500;
      cursor: pointer;
      padding: 0;
      text-decoration: none;
    }

    .link-btn:hover {
      text-decoration: underline;
    }

    /* Progress Bar */
    .progress-track {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: transparent;
      z-index: 100;
    }

    .progress-value {
      height: 100%;
      background: var(--primary);
      width: 0%;
      transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
    }

    /* Modal */
    .modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(4px);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
    }

    .modal-backdrop.active {
      opacity: 1;
      pointer-events: auto;
    }

    .modal-content {
      background: var(--background);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      width: 90%;
      max-width: 600px;
      max-height: 85vh;
      display: flex;
      flex-direction: column;
      box-shadow: var(--shadow-lg);
      transform: scale(0.95);
      transition: transform 0.2s var(--ease-out);
    }

    .modal-backdrop.active .modal-content {
      transform: scale(1);
    }

    .modal-header {
      padding: 16px 24px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .modal-header h3 {
      font-size: 16px;
      font-weight: 600;
    }

    .modal-body {
      padding: 24px;
      overflow-y: auto;
    }

    .modal-footer {
      padding: 16px 24px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      background: var(--surface);
      border-radius: 0 0 var(--radius-xl) var(--radius-xl);
    }

    .code-block {
      background: var(--surface);
      padding: 16px;
      border-radius: var(--radius-md);
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--text-muted);
      border: 1px solid var(--border);
      white-space: pre-wrap;
      max-height: 300px;
      overflow-y: auto;
    }

    /* Toast */
    .toast-container {
      position: fixed;
      bottom: 32px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 2000;
      pointer-events: none;
    }

    .toast {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text-main);
      padding: 12px 24px;
      border-radius: var(--radius-md);
      font-size: 14px;
      font-weight: 500;
      margin-top: 12px;
      box-shadow: var(--shadow-lg);
      display: flex;
      align-items: center;
      gap: 12px;
      transform: translateY(20px);
      opacity: 0;
      transition: all 0.3s var(--ease-out);
    }

    .toast.visible {
      transform: translateY(0);
      opacity: 1;
    }

    .toast.success {
      border-color: var(--success);
    }

    .toast.error {
      border-color: var(--danger);
    }

    .kbd-shortcut {
      display: inline-flex;
      align-items: center;
      background: var(--surface-hover);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 2px 6px;
      font-size: 10px;
      font-family: var(--font-mono);
      color: var(--text-muted);
      margin-left: auto;
    }
  </style>
</head>

<body>

  <!-- Top Bar -->
  <header class="top-bar">
    <div class="brand">
      <div class="brand-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
        </svg>
      </div>
      <span>GoldenSet<span style="color:var(--text-dim)">.AI</span></span>
    </div>

    <div class="controls-group">
      <div class="nav-pill">
        <span id="currentIdx">1</span>
        <span style="color:var(--border-light)">/</span>
        <span id="totalCount">...</span>
      </div>

      <button class="btn-icon" id="prevBtn" onclick="navigate(-1)" title="Previous Image (Left Arrow)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 18l-6-6 6-6" />
        </svg>
      </button>

      <button class="btn-icon" id="nextBtn" onclick="navigate(1)" title="Next Image (Right Arrow)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6" />
        </svg>
      </button>

      <div style="width: 1px; height: 24px; background: var(--border); margin: 0 8px;"></div>

      <button class="btn-secondary" onclick="showPromptModal()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          style="margin-right:8px">
          <circle cx="12" cy="12" r="10" />
          <path d="M12 16v-4" />
          <path d="M12 8h.01" />
        </svg>
        Guide
      </button>

      <button class="btn-secondary" onclick="exportData()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          style="margin-right:8px">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
        Export
      </button>
    </div>
  </header>

  <!-- Progress Bar -->
  <div class="progress-track">
    <div class="progress-value" id="progressFill"></div>
  </div>

  <div class="app-container">
    <!-- Left: Image Canvas -->
    <div class="image-stage">
      <div class="image-wrapper" id="imageWrapper">
        <div class="no-image" id="loadingState">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <polyline points="21 15 16 10 5 21" />
          </svg>
          <div style="margin-top:12px; color: #555; font-size: 13px;">Waiting for images...</div>
        </div>
      </div>

      <div class="image-meta-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
          <polyline points="14 2 14 8 20 8" />
          <line x1="16" y1="13" x2="8" y2="13" />
          <line x1="16" y1="17" x2="8" y2="17" />
          <polyline points="10 9 9 9 8 9" />
        </svg>
        <span class="filename-text" id="filename">filename.jpg</span>
      </div>
    </div>

    <!-- Right: Workspace -->
    <div class="workspace">
      <div class="workspace-content">

        <!-- OCR Section -->
        <div class="form-group">
          <div class="form-header">
            <span class="label">Raw Content (OCR)</span>
            <button class="link-btn" onclick="showPasteModal()">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                style="display:inline; vertical-align:middle; margin-right:4px;">
                <path d="M8 4h10" />
                <path d="M8 8h10" />
                <path d="M8 12h10" />
              </svg>
              Paste JSON
            </button>
          </div>
          <textarea id="ocrText" class="input-field" placeholder="Transcribe text seen in the image..."></textarea>
        </div>

        <!-- Picks List -->
        <div class="picks-container">
          <div class="picks-header">
            <span class="label">Extracted Picks</span>
            <span class="pick-count-badge" id="pickCount">0</span>
          </div>
          <div id="picksList">
            <!-- Picks injected here -->
          </div>
        </div>

        <!-- Add New Pick -->
        <div class="new-pick-area">
          <div class="new-pick-title">Add New Pick</div>

          <div class="grid-2" style="margin-bottom:12px">
            <div>
              <label class="label" style="display:block; margin-bottom:6px">League</label>
              <select id="league" class="input-field">
                <option value="">Select...</option>
                <option value="NFL">NFL</option>
                <option value="NBA">NBA</option>
                <option value="NCAAF">NCAAF</option>
                <option value="NCAAB">NCAAB</option>
                <option value="MLB">MLB</option>
                <option value="NHL">NHL</option>
                <option value="WNBA">WNBA</option>
                <option value="EPL">EPL</option>
                <option value="MLS">MLS</option>
                <option value="UCL">UCL</option>
                <option value="UFC">UFC</option>
                <option value="TENNIS">TENNIS</option>
                <option value="PGA">PGA</option>
                <option value="F1">F1</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div>
              <label class="label" style="display:block; margin-bottom:6px">Type</label>
              <select id="betType" class="input-field">
                <option value="">Select...</option>
                <option value="Moneyline">Moneyline</option>
                <option value="Spread">Spread</option>
                <option value="Total">Total</option>
                <option value="Player Prop">Player Prop</option>
                <option value="Team Prop">Team Prop</option>
                <option value="Game Prop">Game Prop</option>
                <option value="Period">Period</option>
                <option value="Parlay">Parlay</option>
                <option value="Teaser">Teaser</option>
                <option value="Future">Future</option>
                <option value="Unknown">Unknown</option>
              </select>
            </div>
          </div>

          <div style="margin-bottom:12px">
            <label class="label" style="display:block; margin-bottom:6px">Pick Detail</label>
            <input type="text" id="pickValue" class="input-field" placeholder="e.g. Lakers -5.5">
          </div>

          <div class="grid-3" style="margin-bottom:12px">
            <div>
              <label class="label" style="display:block; margin-bottom:6px">Odds</label>
              <input type="number" id="odds" class="input-field" placeholder="-110">
            </div>
            <div>
              <label class="label" style="display:block; margin-bottom:6px">Units</label>
              <input type="number" id="units" class="input-field" step="0.5" value="1">
            </div>
            <div>
              <label class="label" style="display:block; margin-bottom:6px">Side</label>
              <select id="propSide" class="input-field">
                <option value="">None</option>
                <option value="Over">Over</option>
                <option value="Under">Under</option>
              </select>
            </div>
          </div>

          <details style="margin-bottom:16px">
            <summary style="cursor:pointer; font-size:12px; color:var(--text-muted); margin-bottom:8px">Structured
              Fields (optional)</summary>
            <div class="grid-3" style="margin-top:8px">
              <div>
                <label class="label" style="display:block; margin-bottom:6px">Subject</label>
                <input type="text" id="subject" class="input-field" placeholder="LeBron James">
              </div>
              <div>
                <label class="label" style="display:block; margin-bottom:6px">Market</label>
                <input type="text" id="market" class="input-field" placeholder="Pts, Spread, ML">
              </div>
              <div>
                <label class="label" style="display:block; margin-bottom:6px">Line</label>
                <input type="number" id="line" class="input-field" step="0.5" placeholder="25.5">
              </div>
            </div>
          </details>

          <button class="btn-primary" style="width:100%; justify-content:center" onclick="addPick()">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <path d="M12 5v14M5 12h14" />
            </svg>
            Add Pick
          </button>

          <div style="text-align:right">
            <button class="link-btn" style="color:var(--danger); font-size:11px" onclick="clearCurrentPicks()">Clear
              List</button>
          </div>
        </div>

      </div>

      <!-- Footer Actions -->
      <div class="action-bar">
        <button class="btn-secondary" onclick="skip()" style="flex:1">Skip</button>
        <button class="btn-primary" onclick="saveAndNext()" style="flex:2; font-size:14px">
          Save & Next Image
          <span class="kbd-shortcut">Ctrl+S</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Toasts -->
  <div class="toast-container" id="toastContainer"></div>

  <!-- MODALS -->

  <!-- Prompt Modal -->
  <div class="modal-backdrop" id="promptModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3>AI Formatting Guide</h3>
        <button class="btn-icon" style="border:none" onclick="closePromptModal()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <pre id="promptContent" class="code-block"></pre>
      </div>
      <div class="modal-footer">
        <button class="btn-secondary" onclick="closePromptModal()">Close</button>
        <button class="btn-primary" onclick="copyPrompt()">Copy to Clipboard</button>
      </div>
    </div>
  </div>

  <!-- Paste Modal -->
  <div class="modal-backdrop" id="pasteModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3>Import JSON Data</h3>
        <button class="btn-icon" style="border:none" onclick="closePasteModal()">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="modal-body">
        <p style="font-size:13px; color:var(--text-muted); margin-bottom:12px">Paste a JSON object or array of picks.
          Auto-detects keys (lg/league, p/pick, etc).</p>
        <textarea id="jsonInput" class="input-field" style="height:200px; font-family:var(--font-mono)"
          placeholder='[{"lg": "NBA", "p": "Lakers -5"}, {"lg": "NFL", "p": "Chiefs ML"}]'></textarea>
      </div>
      <div class="modal-footer">
        <button class="btn-secondary" onclick="closePasteModal()">Cancel</button>
        <button class="btn-primary" onclick="applyPastedJson()">Import Picks</button>
      </div>
    </div>
  </div>

  <script>
    // --- STATE & DATA ---
    let images = [];
    let currentIndex = 0;
    let annotations = {};
    let currentPicks = [];

    // --- INIT ---
    window.onload = function () {
      loadState();
      fetchImages();
      setupShortcuts();
    };

    // --- CORE FUNCTIONS ---
    function loadState() {
      try {
        const saved = localStorage.getItem('goldenSetAnnotationsV2');
        if (saved) annotations = JSON.parse(saved);
      } catch (e) { console.error(e); }
    }

    function saveState() {
      localStorage.setItem('goldenSetAnnotationsV2', JSON.stringify(annotations));
    }

    async function fetchImages() {
      try {
        const res = await fetch('/api/images');
        const data = await res.json();
        images = data.images || [];
        document.getElementById('totalCount').textContent = images.length;

        if (images.length > 0) {
          const firstUnannotated = images.findIndex(img => !annotations[img.path]);
          currentIndex = firstUnannotated >= 0 ? firstUnannotated : 0;
          renderImage();
        } else {
          showToast('No images found', 'error');
        }
      } catch (e) {
        showToast('Server connection failed', 'error');
      }
    }

    function renderImage() {
      if (images.length === 0) return;
      const img = images[currentIndex];
      const annotation = annotations[img.path];

      // Update Image
      const wrapper = document.getElementById('imageWrapper');
      wrapper.innerHTML = `<img src="/${img.path}" alt="${img.filename}">`;

      document.getElementById('filename').textContent = img.filename;

      // Update Controls
      document.getElementById('currentIdx').textContent = currentIndex + 1;
      document.getElementById('prevBtn').disabled = currentIndex === 0;
      document.getElementById('nextBtn').disabled = currentIndex === images.length - 1;

      // Update Progress
      const annotatedCount = Object.values(annotations).filter(a => a.expected_picks?.length > 0).length;
      const pct = (annotatedCount / images.length) * 100;
      document.getElementById('progressFill').style.width = `${pct}%`;

      // Hydrate Data
      if (annotation) {
        document.getElementById('ocrText').value = annotation.ocr_text || '';
        currentPicks = [...(annotation.expected_picks || [])];
      } else {
        document.getElementById('ocrText').value = '';
        currentPicks = [];
      }

      clearForm();
      renderPicksList();
    }

    function renderPicksList() {
      const listEl = document.getElementById('picksList');
      document.getElementById('pickCount').textContent = currentPicks.length;

      if (currentPicks.length === 0) {
        listEl.innerHTML = `<div style="text-align:center; padding:32px; color:var(--text-dim); border:2px dashed var(--border); border-radius:var(--radius-md)">
          <div style="font-size:13px">No picks added</div>
          <div style="font-size:11px; margin-top:4px">Use the form or paste JSON</div>
        </div>`;
        return;
      }

      listEl.innerHTML = currentPicks.map((pick, i) => `
        <div class="pick-card">
          <div class="pick-content">
            <h4>${escapeHtml(pick.pick)}</h4>
            <div class="pick-tags">
              <span class="tag">${pick.league}</span>
              <span class="tag">${pick.type}</span>
              ${pick.odds ? `<span class="tag odds">${pick.odds > 0 ? '+' : ''}${pick.odds}</span>` : ''}
              ${pick.units !== 1 ? `<span class="tag">${pick.units}u</span>` : ''}
              ${pick.prop_side ? `<span class="tag">${pick.prop_side}</span>` : ''}
            </div>
            ${pick.subject || pick.market ? `<div style="font-size:10px; color:var(--text-dim); margin-top:4px">${pick.subject || ''} ${pick.market ? '| ' + pick.market : ''} ${pick.line != null ? '| ' + pick.line : ''}</div>` : ''}
          </div>
          <button class="btn-remove" onclick="removePick(${i})">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </div>
      `).join('');
    }

    // --- ACTIONS ---

    function addPick() {
      const league = document.getElementById('league').value;
      const type = document.getElementById('betType').value;
      const pick = document.getElementById('pickValue').value.trim();
      const odds = document.getElementById('odds').value;
      const units = document.getElementById('units').value;
      const subject = document.getElementById('subject')?.value?.trim() || null;
      const market = document.getElementById('market')?.value?.trim() || null;
      const line = document.getElementById('line')?.value;
      const propSide = document.getElementById('propSide')?.value || null;

      if (!league || !type || !pick) {
        showToast('League, Type, and Pick are required', 'error');
        return;
      }

      currentPicks.push({
        league, type, pick,
        odds: odds ? parseInt(odds) : null,
        units: units ? parseFloat(units) : 1.0,
        subject: subject || null,
        market: market || null,
        line: line ? parseFloat(line) : null,
        prop_side: propSide || null
      });

      clearForm();
      renderPicksList();
      showToast('Pick added', 'success');
      document.getElementById('pickValue').focus();
    }

    function removePick(i) {
      currentPicks.splice(i, 1);
      renderPicksList();
    }

    function clearCurrentPicks() {
      if (confirm('Clear all picks?')) {
        currentPicks = [];
        renderPicksList();
      }
    }

    function saveAndNext() {
      const ocr = document.getElementById('ocrText').value.trim();
      if (!ocr) return showToast('OCR text required', 'error');
      if (currentPicks.length === 0) return showToast('Add at least one pick', 'error');

      const img = images[currentIndex];
      annotations[img.path] = { ocr_text: ocr, expected_picks: [...currentPicks] };
      saveState();

      showToast('Saved!', 'success');
      if (currentIndex < images.length - 1) navigate(1);
    }

    function skip() {
      navigate(1);
    }

    function navigate(d) {
      const next = currentIndex + d;
      if (next >= 0 && next < images.length) {
        currentIndex = next;
        renderImage();
      }
    }

    function exportData() {
      const valid = Object.entries(annotations).filter(([_, v]) => v.expected_picks?.length > 0);
      if (valid.length === 0) return showToast('Nothing to export', 'error');

      const lines = valid.map(([path, data]) => JSON.stringify({
        image_path: path,
        ocr_text: data.ocr_text,
        expected_picks: data.expected_picks
      }));

      const blob = new Blob([lines.join('\n')], { type: 'application/jsonl' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `golden_set_${new Date().toISOString().slice(0, 10)}.jsonl`;
      a.click();
      URL.revokeObjectURL(url);
      showToast(`Exported ${valid.length} items`, 'success');
    }

    // --- JSON PARSER ---
    function applyPastedJson() {
      try {
        const raw = document.getElementById('jsonInput').value;
        const data = JSON.parse(raw);
        const list = Array.isArray(data) ? data : [data];

        let count = 0;
        list.forEach(item => {
          const p = {
            league: item.lg || item.league || 'Other',
            type: item.ty || item.type || 'Unknown',
            pick: item.p || item.pick || item.pick_value || '',
            odds: item.od ?? item.odds ?? item.odds_american ?? null,
            units: item.u ?? item.units ?? 1.0,
            // Structured fields (v3.0 spec)
            subject: item.sub || item.subject || null,
            market: item.mkt || item.market || null,
            line: item.ln ?? item.line ?? null,
            prop_side: item.side || item.prop_side || null
          };
          if (p.pick) {
            currentPicks.push(p);
            count++;
          }
        });

        if (count > 0) {
