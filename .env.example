# ==========================================
# CapperSuite CLI v4.6.1 - Environment Config
# ==========================================
# Copy this file to .env and fill in your values.

# --- REQUIRED: Telegram API ---
API_ID=
API_HASH=

# --- REQUIRED: AI Extraction ---
OPENROUTER_API_KEY=

# --- REQUIRED: Database ---
SUPABASE_URL=
SUPABASE_KEY=

# --- REQUIRED: Target Channels ---
# Comma-separated channel IDs
TARGET_TELEGRAM_CHANNEL_ID=

# --- OPTIONAL: Discord ---
DISCORD_TOKEN=
TARGET_DISCORD_CHANNEL_ID=

# --- OPTIONAL: Proxy ---
# Format: http://user:pass@host:port or socks5://host:port
PROXY_URL=

# --- OPTIONAL: Consensus Engine ---
# Set to "true" to enable AI consensus refinement (costs extra tokens)
ENABLE_CONSENSUS=false
