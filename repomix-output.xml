    elapsed = time.perf_counter() - start
    results["all_leagues_cached"] = elapsed
    log(f"        Cached: {elapsed:.3f}s ({len(scores)} games)", Colors.GREEN)
    
    # Test 2: Fetch only NBA + NFL (common case)
